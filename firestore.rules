rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdult(birthDate) {
      // Very basic age check for rules (30+ years)
      // duration.value() returns seconds. 30 years approx: 30 * 365.25 * 24 * 60 * 60
      return duration.value(request.time - timestamp.value(birthDate)) >= 30 * 31557600;
    }

    // Users
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid 
          && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100
          && data.birthDate is string // Validated as string then converted to timestamp in isAdult
          && data.neighborhood is string && data.neighborhood.size() <= 100
          && (data.verificationStatus in ['none', 'pending', 'verified', 'rejected'])
          && data.subscriptionTier in ['free', 'premium', 'executive'];
      }

      allow get: if isSignedIn(); // Allow reading profiles for discovery
      allow list: if isSignedIn(); // Allow discovery queries
      allow create: if isOwner(userId) 
        && isValidUser(incoming()) 
        && isAdult(incoming().birthDate)
        && incoming().createdAt == request.time;
      
      allow update: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().birthDate == existing().birthDate // Immutable birthdate
        && (
          // Standard Update: bio, photo, neighborhood, preferences
          incoming().diff(existing()).affectedKeys().hasOnly(['bio', 'photoURL', 'neighborhood', 'interestedIn', 'updatedAt', 'swipeCount', 'displayName'])
          || 
          // Verification Request
          (incoming().verificationStatus == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(['verificationStatus', 'updatedAt']))
        )
        && incoming().updatedAt == request.time;
    }

    // Matches
    match /matches/{matchId} {
      function isParticipant() {
        return isSignedIn() && (request.auth.uid in existing().users);
      }

      function isValidMatch(data) {
        return data.users.size() == 2 
          && data.users.hasAll([request.auth.uid])
          && data.updatedAt == request.time;
      }

      allow get, list: if isSignedIn() && (request.auth.uid in resource.data.users);
      
      allow create: if isSignedIn() 
        && isValidMatch(incoming())
        && incoming().isMutual == false; // Initial like

      allow update: if isParticipant()
        && incoming().users == existing().users
        && (
          // Action: Mutual Match (second user likes back)
          (incoming().isMutual == true && incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'isMutual', 'updatedAt']))
          ||
          // Action: Update last message
          (incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt']))
        )
        && incoming().updatedAt == request.time;

      // Messages
      match /messages/{messageId} {
        allow read, list: if isParticipant();
        allow create: if isParticipant() 
          && incoming().senderId == request.auth.uid
          && incoming().createdAt == request.time
          && incoming().text is string && incoming().text.size() <= 1000;
      }
    }
  }
}
